   "source": [
    "import cv2\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "img = cv2.imread(\"mani2.jpg\")\n",
    "\n",
    "# Increase brightness\n",
    "bright = cv2.convertScaleAbs(img, alpha=1, beta=50)\n",
    "\n",
    "plt.imshow(cv2.cvtColor(bright, cv2.COLOR_BGR2RGB))\n",
    "plt.title(\"Brightness Increased\")\n",
    "plt.axis(\"off\")\n",
    "plt.show()"
   ]
  }
 ],
