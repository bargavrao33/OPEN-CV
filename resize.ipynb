   "source": [
    "# Program to resize an image\n",
    "import cv2\n",
    "import matplotlib.pyplot as plt\n",
    "img=cv2.imread(\"mani2.jpg\")\n",
    "img=cv2.cvtColor(img,cv2.COLOR_BGR2RGB)\n",
    "img=cv2.resize(img,(400,400))\n",
    "plt.imshow(img)\n",
    "plt.show()"
   ]
